{
    "java.project.sourcePaths": [
        "src"
    ],
    "java.project.outputPath": "bin",
    "java.project.referencedLibraries": [
        "lib/**/*.jar"
    ],
    "code-runner.executorMap": {
        "java": "cd $dir && javac -cp \".:../lib/*\" $fileName && java -cp \".:../lib/*\" $fileNameWithoutExt"
    }
}